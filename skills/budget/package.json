{
  "name": "@agent-collab/budget",
  "version": "0.2.0",
  "description": "Budget engine - Family finance CLI with cascade updates for finance/ CSV store",
  "type": "module",
  "main": "dist/skill-cli.js",
  "types": "dist/skill-cli.d.ts",
  "bin": {
    "agent-collab-budget": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rm -rf dist",
    "bundle": "npm run build && node -e \"const{build}=await import('esbuild');await build({entryPoints:['dist/skill-cli.js'],bundle:true,platform:'node',format:'esm',outfile:'scripts/budget.js',minify:false})\"",
    "publish:skill": "bash publish-skill.sh"
  },
  "dependencies": {
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "esbuild": "^0.24.0",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "files": [
    "dist",
    "scripts",
    "README.md"
  ],
  "license": "MIT"
}
