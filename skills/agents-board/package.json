{
  "name": "@agent-collab/board",
  "version": "0.1.0",
  "description": "Agent Collaboration Board - Shared communication infrastructure for multi-agent development",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "board": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "bundle": "esbuild dist/skill-cli.js --bundle --platform=node --target=node18 --format=esm --outfile=scripts/board.js --external:better-sqlite3",
    "prebundle": "npm run build",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:run": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src --ext .ts",
    "clean": "rm -rf dist",
    "publish:skill": "bash publish-skill.sh"
  },
  "dependencies": {
    "better-sqlite3": "^11.7.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.10.5",
    "@typescript-eslint/eslint-plugin": "^8.19.1",
    "@typescript-eslint/parser": "^8.19.1",
    "esbuild": "^0.27.3",
    "eslint": "^9.17.0",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "keywords": [
    "agent-collab",
    "agent-collab-board",
    "agent-collaboration",
    "multi-agent",
    "mcp",
    "board",
    "ai-agents"
  ],
  "license": "MIT"
}
