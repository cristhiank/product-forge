{
  "name": "forge-mission-control",
  "version": "0.1.0",
  "description": "Local web dashboard for navigating Forge project artifacts, backlog, and agent activity",
  "type": "module",
  "bin": {
    "forge-ui": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc && cd client && npx vite build --outDir ../dist/client",
    "build:client": "cd client && npx vite build --outDir ../dist/client",
    "build:server": "tsc",
    "dev": "tsc --watch",
    "dev:client": "cd client && npx vite",
    "dev:server": "tsc && node dist/cli.js . --port 3700",
    "start": "node dist/cli.js"
  },
  "dependencies": {
    "@fastify/static": "^9.0.0",
    "chokidar": "^4.0.0",
    "commander": "^12.0.0",
    "fastify": "^5.0.0",
    "gray-matter": "^4.0.3",
    "open": "^10.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.5.0"
  },
  "engines": {
    "node": ">=20"
  }
}
